# Função para detectar erro e gerar prompt para solução
gerar_prompt_erro <- function(expr, descricao_objetivo = "", contexto = "") {
  
  tryCatch(
    {
      resultado <- eval(expr)
      cat("✅ Código executado com sucesso\n")
      return(resultado)
    },
    
    error = function(e) {
      
      codigo_texto <- paste(deparse(expr), collapse = "\n")
      erro_msg <- e$message
      
      # Sugestões automáticas
      sugestao <- ""
      
      if (grepl("object '.*' not found", erro_msg)) {
        sugestao <- "Verifique se o objeto foi criado ou carregado corretamente."
      } else if (grepl("could not find function", erro_msg)) {
        sugestao <- "A função pode ser de um pacote não carregado. Use library()."
      } else {
        sugestao <- "Revise a sintaxe e os objetos utilizados."
      }
      
      # Prompt gerado
      prompt <- paste0(
        "Estou tendo um erro em um script em R.\n\n",
        "Código:\n", codigo_texto, "\n\n",
        "Erro apresentado:\n", erro_msg, "\n\n",
        "O que eu esperava que o código fizesse:\n", descricao_objetivo, "\n\n",
        "Contexto adicional:\n", contexto, "\n\n",
        "Pode me explicar:\n",
        "1. O que significa esse erro?\n",
        "2. Onde está o problema?\n",
        "3. Como corrigir?\n",
        "4. Mostrar código corrigido."
      )
      
      cat("ERRO DETECTADO\n\n")
      cat(prompt, "\n\n")
      
      cat("💡 SUGESTÃO:\n")
      cat(sugestao, "\n")
    }
  )
}

