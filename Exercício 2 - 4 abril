create_data <- function(data, path) {
  write.csv(data, path, row.names = FALSE)
}


read_data <- function(path) {
  read.csv(path)
}

update_data <- function(data, condition, new_values) {
  data[condition, ] <- new_values
  return(data)
}


delete_data <- function(data, condition) {
  data <- data[!condition, ]
  return(data)
}


