  orcamento = 500000.00,
  data_inicio = as.Date("2026-04-01"),
  data_fim = as.Date("2027-04-01")
)

programa2 <- list(
  nome = "Vigilância epidemiológica da Febre Amarela",
  objetivos = "Levantamento de dados para Febre Amarela e os macacos; observar a quantidade da população afetada",
  publico_alvo = "Frequentadores de parques ecológicos",
  orcamento = 900000.00,
  data_inicio = as.Date("2026-08-01"),
  data_fim = as.Date("2028-08-01")
)

programa3 <- list(
  nome = "Vigilância epidemiológica da Leishmaniose Tegumentar",
  objetivos = "Levantamento da subnotificação das doenças; Soroprevalência da doença no estado; Análise espaço-temporal",
  publico_alvo = "Todos os moradores do estado",
  orcamento = 1000000.00,
  data_inicio = as.Date("2026-06-01"),
  data_fim = as.Date("2030-06-01")
)

# Criar lista geral com todos os programas
programas <- list(programa1, programa2, programa3)

# 2. CALCULAR O ORÇAMENTO TOTAL
orcamento_total <- programa1$orcamento + programa2$orcamento + programa3$orcamento
print(paste("Orçamento total: R$", format(orcamento_total, big.mark = ".", decimal.mark = ",")))

# 3. IDENTIFICAR O PROGRAMA COM MAIOR ORÇAMENTO
orcamentos <- c(programa1$orcamento, programa2$orcamento, programa3$orcamento)
nomes <- c(programa1$nome, programa2$nome, programa3$nome)
