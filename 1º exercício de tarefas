# Dados fornecidos
notas <- c(8.5, 7.0, 9.2, 6.8, 8.0, 7.5, 9.0, 5.5, 8.8, 7.2)

# 1. ORGANIZAÇÃO

# Ordenar as notas em ordem crescente
notas_crescente <- sort(notas)
print("Notas em ordem crescente:")
print(notas_crescente) 


# Inverter a ordem das notas (da maior para a menor)
notas_decrescente <- rev(sort(notas))
print("Notas em ordem decrescente:")
print(notas_decrescente) 

# Calcular a média das notas
media_notas <- mean(notas)
print(paste("Média das notas:", round(media_notas, 2))) 

# Encontrar a mediana das notas
mediana_notas <- median(notas)
print(paste("Mediana das notas:", round(mediana_notas, 2))) 

# Determinar a nota mais alta e a mais baixa
nota_maxima <- max(notas)
nota_minima <- min(notas)
print(paste("Nota mais alta:", nota_maxima)) 
print(paste("Nota mais baixa:", nota_minima)) 

# Calcular o desvio padrão das notas
desvio_padrao <- sd(notas)
print(paste("Desvio padrão das notas:", round(desvio_padrao, 2))) 

# 3. FREQUÊNCIA

# Criar tabela de frequências
tabela_frequencia <- table(notas)
print("Tabela de frequências das notas:")
print(tabela_frequencia) 

# 4. RESUMO ESTATÍSTICO COMPLETO

print("Resumo estatístico completo das notas:")
print(summary(notas)) 

# Visualização adicional: frequência ordenada
print("Frequência das notas (ordenada):")
print(sort(tabela_frequencia, decreasing = TRUE)) 

