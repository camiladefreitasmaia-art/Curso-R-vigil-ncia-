# Projeto Final - Taxa de Nascidos Vivos (TO - 2019)


# =========================
# 1. Configuração inicial
# =========================
library(microdatasus)
library(dplyr)
library(ggplot2)

# Caminho de saída
caminho_saida <- "C:/Users/isado/Desktop/R"

# =========================
# 2. Coleta de dados
# =========================
dados_sim <- fetch_datasus(
  year_start = 2019,
  year_end = 2019,
  uf = "TO",
  information_system = "SIM-DO"
)

dados_sinasc <- fetch_datasus(
  year_start = 2019,
  year_end = 2019,
  uf = "TO",
  information_system = "SINASC"
)

# =========================
# 3. Limpeza e preprocessamento
# =========================
dados_sim <- process_sim(dados_sim)
dados_sinasc <- process_sinasc(dados_sinasc)

# =========================
# 4. Transformação
# =========================
total_nascidos <- dados_sinasc %>%
  summarise(total = n()) %>%
  pull(total)

pop_aprox <- dados_sim %>%
  summarise(total = n()) %>%
  pull(total)

# =========================
# 5. Análise
# =========================
taxa_natalidade <- (total_nascidos / pop_aprox) * 1000

# =========================
# 6. Visualização (salvando gráfico)
# =========================
grafico <- ggplot(data.frame(valor = taxa_natalidade), aes(x = "", y = valor)) +
  geom_col() +
  labs(
    title = "Taxa de Nascidos Vivos - TO (2019)",
    y = "Taxa por 1.000 habitantes",
    x = ""
  ) +
  theme_minimal()

# Salvar gráfico
ggsave(
  filename = paste0(caminho_saida, "/grafico_taxa_natalidade.png"),
  plot = grafico,
  width = 6,
  height = 4
)

# =========================
# 7. Geração do relatório
# =========================
relatorio <- paste(
  "====================================",
  "\nRELATÓRIO - TAXA DE NASCIDOS VIVOS",
  "\nEstado: Tocantins (TO)",
  "\nAno: 2019",
  "\n====================================",
  "\nTotal de nascidos vivos:", total_nascidos,
  "\nPopulação aproximada:", pop_aprox,
  "\nTaxa de natalidade (por 1.000 hab.):", round(taxa_natalidade, 2),
  "\n====================================",
  "\nObservação:",
  "\nA população foi estimada com base nos dados disponíveis (SIM),",
  "\npodendo diferir dos valores oficiais do IBGE."
)

# Salvar relatório em arquivo .txt
writeLines(
  relatorio,
  con = paste0(caminho_saida, "/relatorio_taxa_natalidade.txt")
)
